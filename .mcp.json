{
  "mcpServers": {
    "expert-mcp": {
      "command": "node",
      "args": [
        "/root/mcp-server/dist/index.js"
      ]
    },
    "filesystem": {
      "command": "node",
      "args": [
        "/usr/lib/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "/root"
      ]
    },
    "memory": {
      "command": "node",
      "args": [
        "/usr/lib/node_modules/@modelcontextprotocol/server-memory/dist/index.js"
      ]
    },
    "sqlite": {
      "command": "node",
      "args": [
        "/usr/lib/node_modules/mcp-sqlite/mcp-sqlite-server.js"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@ama-mcp/github"
      ],
      "env": {
        "GITHUB_TOKEN": ""
      }
    },
    "syke": {
      "command": "npx",
      "args": [
        "-y",
        "@syke1/mcp-server@latest"
      ]
    },
    "analyzer": {
      "command": "/root/.local/bin/uvx",
      "args": [
        "mcp-server-analyzer"
      ]
    },
    "sequential-thinking": {
      "command": "node",
      "args": [
        "/usr/lib/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ]
    },
    "semgrep": {
      "command": "/root/.local/bin/uvx",
      "args": [
        "semgrep-mcp"
      ]
    }
  }
}
