# ============================================================
#  ZENIC-AGENTS v16 — Environment Variables (Phase 2: Scalability)
#
#  Copy this file to .env and customize for your environment:
#    cp .env.example .env
#
#  Never commit .env to version control — it may contain secrets.
# ============================================================

# ── Application Environment ─────────────────────────────────
# Determines which database backend and features to use.
#   development  → SQLite (default, no external services needed)
#   production   → PostgreSQL + Redis (requires docker compose up)
ZENIC_ENV=development

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (only used when ZENIC_ENV=production).
# Supports SQLAlchemy-style DSN — the +asyncpg driver is auto-stripped
# by PostgreSQLDatabase._convert_dsn() for asyncpg compatibility.
#
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Default matches docker-compose.yml: zenic/zenic@localhost:5432/zenic_db
DATABASE_URL=postgresql+asyncpg://zenic:zenic@localhost:5432/zenic_db

# ── Cache ───────────────────────────────────────────────────
# Cache provider selection.
#   memory    → In-process LRU cache (default, no external services)
#   redis     → Redis cache (requires docker compose up)
CACHE_PROVIDER=memory

# Redis connection URL (only used when CACHE_PROVIDER=redis).
#
# Format: redis://<host>:<port>/<db_number>
# Default matches docker-compose.yml: localhost:6379/db0
CACHE_URL=redis://localhost:6379/0

# ── Redis (standalone) ─────────────────────────────────────
# General Redis URL for session storage, rate limiting, etc.
# Can be the same as CACHE_URL or point to a different Redis instance.
REDIS_URL=redis://localhost:6379/0

# ── Vector Store (Phase 4.1) ───────────────────────────────
# Enable/disable vector search operations.
#   true     → Enable vector store (default)
#   false    → Disable vector operations
VECTOR_ENABLED=true

# Embedding dimensions for the vector store.
# Must match the model output (384 for fastembed/all-MiniLM-L6-v2).
VECTOR_DIMENSIONS=384

# HNSW index parameters for PostgreSQL pgvector.
# M: Graph connectivity (higher = better recall, more memory)
# ef_construction: Index build quality (higher = slower build, better recall)
# ef_search: Query-time search quality (higher = slower query, better recall)
VECTOR_HNSW_M=16
VECTOR_HNSW_EF_CONSTRUCTION=64
VECTOR_EF_SEARCH=40

# Vector store table name in PostgreSQL.
VECTOR_TABLE_NAME=zenic_vectors

# ── REQUEST TIMEOUT ───────────────────────────────────────
# Timeout en segundos para operaciones del engine (default: 120)
ZENIC_REQUEST_TIMEOUT=120

# ── DEVELOPMENT MODE ──────────────────────────────────────
# ⚠️ SECURITY: Only for local development. NEVER enable in production.
# When set to 1 + NODE_ENV=development, allows auth bypass with viewer role.
# Without this, RBAC and tenant endpoints are locked (fail-closed).
# Default is 0 (disabled) — must be explicitly enabled for development.
ZENIC_DEV_MODE=0

# ── HSTS (HTTP Strict Transport Security) ────────────────────────
# Controls whether the 'preload' directive is included in the
# Strict-Transport-Security header.
#   true    => max-age=63072000; includeSubDomains; preload (default, for production domains)
#   false   => max-age=63072000; includeSubDomains (for staging domains not in preload lists)
# Only applies in production (NODE_ENV=production).
# Set to false for staging/pre-production environments to avoid
# accidentally submitting to browser HSTS preload lists.
ZENIC_HEADERS_HSTS_PRELOAD=true

# ── GATEWAY AUTH SECRETS ──────────────────────────────────
# Required for tenant authentication in production.
# If not set, tenant endpoints are LOCKED (fail-closed, INVARIANT 4).
# Must be changed to a real secret in production — placeholder is detected by INSECURE_DEFAULTS.
ZENIC_TENANT_SECRET=change-me-in-production

# Required for admin endpoints. If not set, admin access is DISABLED.
# Must be changed to a real secret in production — placeholder is detected by INSECURE_DEFAULTS.
ZENIC_ADMIN_KEY=change-me-in-production

# ── KMS (Key Management Service) ──────────────────────────────
# Backend used by EncryptionManager to source the master encryption key.
# Multiple providers are tried in order until one returns a key:
#   1. VaultProvider (if VAULT_ADDR is configured and hvac is installed)
#   2. KeyringProvider (if keyring library is installed)
#   3. EnvKeyProvider (reads ZENIC_DB_PASSPHRASE, always available as fallback)
#
# The master key is used for Fernet symmetric encryption and SQLCipher.
# All providers fall back to ZENIC_DB_PASSPHRASE if they don't find a key.
#
# For KEYRING provider — OS keychain (macOS Keychain, Linux Secret Service, Windows Credential Locker):
#   Requires: pip install keyring
#   Provision: python -c "from src.core.defense import KeyringProvider; KeyringProvider().provision()"
#
# For VAULT provider — HashiCorp Vault (production, requires network):
#   Requires: pip install hvac
#   Vault path: secret/data/zenic/master-key (configurable in kms_backend.py)
#   Vault key field: "key" (configurable — must contain the master passphrase)
VAULT_ADDR=
VAULT_TOKEN=

# ── Docker Compose Quick Start ─────────────────────────────
# 1. Start infrastructure services:
#      docker compose up -d
#
# 2. Switch to production mode:
#      ZENIC_ENV=production
#      DATABASE_URL=postgresql+asyncpg://zenic:zenic@localhost:5432/zenic_db
#      CACHE_PROVIDER=redis
#      CACHE_URL=redis://localhost:6379/0
#      REDIS_URL=redis://localhost:6379/0
#
# 3. Run the agent or tests:
#      python -m src.entrypoints.main
#      pytest tests/test_postgresql_e2e.py -v
#      pytest tests/test_redis_integration.py -v
