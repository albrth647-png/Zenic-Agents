# Zenic-Agents v3.0.0 — Variables de Entorno
# Copia este archivo a .env y configura tus valores

# Base de datos
DATABASE_URL=
DATABASE_PATH=

# Canales proactivos
PROACTIVE_CHANNEL=telegram
PROACTIVE_RECIPIENT=
WHATSAPP_API_URL=
TELEGRAM_API_URL=
TELEGRAM_BOT_TOKEN=

# SNA — Sistema de Navegación Autónoma
SNA_ENABLED=true
SNA_SCAN_INTERVAL=300
SNA_ALERT_COOLDOWN=1800
SNA_RATE_LIMIT=5
SNA_THRESHOLD_CONFIG=

# Autopilot
AUTOPILOT_ENABLED=true
AUTOPILOT_AUTONOMY=semi_autonomous

# Datos
ZENIC_DATA_PATH=/home/z/my-project
